<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>8f3b9c2a-4d5e-6f7a-b8c9-d0e1f2a3b4c5</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Aditum Bio</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="EA Book IQ" />
  <Description DefaultValue="Intelligent conference room booking for executive assistants." />
  <IconUrl DefaultValue="https://ea-bookiq.onrender.com/icons/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://ea-bookiq.onrender.com/icons/icon-128.png" />
  <SupportUrl DefaultValue="https://ea-bookiq.onrender.com" />

  <AppDomains>
    <AppDomain>https://ea-bookiq.onrender.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ea-bookiq.onrender.com/taskpane" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile.Url" />

          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="openTaskpane">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://ea-bookiq.onrender.com/icons/icon-64.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://ea-bookiq.onrender.com/icons/icon-64.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://ea-bookiq.onrender.com/icons/icon-128.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://ea-bookiq.onrender.com/functions.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://ea-bookiq.onrender.com/taskpane" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="EA Book IQ" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Book IQ" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open EA Book IQ room booking assistant" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
