<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>8f3b9c2a-4d5e-6f7a-b8c9-d0e1f2a3b4c5</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Aditum Bio</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="EA Book IQ" />
  <Description DefaultValue="Intelligent conference room booking for executive assistants." />
  <IconUrl DefaultValue="https://ea-bookiq.onrender.com/icons/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://ea-bookiq.onrender.com/icons/icon-128.png" />
  <SupportUrl DefaultValue="https://ea-bookiq.onrender.com" />

  <AppDomains>
    <AppDomain>https://ea-bookiq.onrender.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ea-bookiq.onrender.com/taskpane" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

</OfficeApp>
